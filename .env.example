# ---------- Postgres ----------
POSTGRES_USER=ford
POSTGRES_PASSWORD=ford_dev_password
POSTGRES_DB=ford
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- RabbitMQ ----------
RABBITMQ_USER=ford
RABBITMQ_PASSWORD=ford_dev_password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------- Secrets ----------
# Both must be at least 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-jwt-secret-must-be-32-chars-or-longer-xx
EVENT_SIGNING_SECRET=change-me-event-secret-must-be-32-chars-or-longer

# ---------- JWT ----------
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=https://localhost,https://localhost:8443

# ---------- Anthropic (Claude) ----------
# Required for vehicle-service. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
